{
  "name": "rest-express",
  "version": "1.0.0",
  "type": "module",
  "license": "MIT",
  "scripts": {
    "dev": "TSX_DISABLE_IPC=1 NODE_ENV=development tsx server/index.ts",
    "dev:watch": "TSX_DISABLE_IPC=1 NODE_ENV=development tsx watch --exclude 'uploads/**' --exclude 'artifacts/**' --exclude 'dist/**' --exclude 'vite.config.ts.timestamp-*' server/index.ts",
    "dev:local:start": "bash scripts/dev-workspace/local-apps.sh start",
    "dev:local:ensure": "bash scripts/dev-workspace/local-apps.sh ensure",
    "dev:local:stop": "bash scripts/dev-workspace/local-apps.sh stop",
    "dev:local:restart": "bash scripts/dev-workspace/local-apps.sh restart",
    "dev:local:status": "bash scripts/dev-workspace/local-apps.sh status",
    "build": "vite build && esbuild server/index.ts --platform=node --packages=external --bundle --format=esm --outdir=dist",
    "start": "NODE_ENV=production node dist/index.js",
    "check": "export TMPDIR=/tmp TSX_DISABLE_IPC=1; tsc && npm run -s check:db-naming-alignment && npm run -s audit:storage-governance && npm run -s check:theme-contracts && npm run -s audit:theme-architecture:strict && npm run -s audit:theme-ui:strict && npm run -s check:ui-contrast && npm run -s check:uikit-parity && npm run -s check:uikit-coverage && npm run -s check:page-primitive-adoption && npm run -s check:route-domain-primitive-parity && npm run -s audit:ui-white-label",
    "test": "NODE_OPTIONS=--max-old-space-size=8192 npx jest --runInBand",
    "test:server": "NODE_OPTIONS=--max-old-space-size=8192 npx jest --runInBand server/tests",
    "test:client": "npx jest --runInBand client/src/tests",
    "test:viewer-critical": "NODE_OPTIONS=--max-old-space-size=4096 npx jest --runInBand client/src/tests/courseBackLink.test.ts client/src/tests/lessonNavigationState.test.ts client/src/tests/lessonViewerNavigation.test.ts client/src/tests/translationFlowStatus.test.ts client/src/tests/podcastScriptTools.test.ts client/src/tests/courseLanguageRouting.test.ts client/src/tests/themeEditorApi.test.ts client/src/tests/themePaletteBuilder.test.ts client/src/tests/themeEditorStateSync.test.ts client/src/tests/PreviewParity.test.tsx server/tests/languageArtifactService.test.ts server/tests/lessonProgressService.test.ts server/tests/translationWizardStateService.test.ts server/tests/languageSecurityAvailability.test.ts server/tests/brandingAccessPolicy.test.ts server/tests/brandingSecurityService.test.ts server/tests/themeComponentContracts.test.ts",
    "test:critical": "npm run -s test:viewer-critical",
    "test:critical:integration": "npx jest --runInBand server/tests/podcastPlaybackAccess.test.ts server/tests/translationIndexService.integration.test.ts",
    "coverage": "npx jest --coverage",
    "check:ui-contrast": "scripts/check-ui-contrast-patterns.sh",
    "check:uikit-parity": "scripts/check-uikit-parity.sh",
    "check:uikit-coverage": "node scripts/check-uikit-coverage.mjs",
    "check:page-primitive-adoption": "node scripts/check-page-primitive-adoption.mjs",
    "check:route-domain-primitive-parity": "node scripts/check-route-domain-primitive-parity.mjs",
    "check:route-domain-primitive-parity:baseline": "node scripts/check-route-domain-primitive-parity.mjs --write-baseline",
    "parity:remediate": "node scripts/remediate-uikit-parity.mjs",
    "check:db-naming-alignment": "node scripts/check-db-naming-alignment.mjs",
    "audit:storage-governance": "tsx scripts/audit-storage-governance.ts",
    "audit:storage-reference-integrity": "tsx scripts/audit-storage-reference-integrity.ts",
    "audit:ui-white-label": "scripts/audit-ui-white-label.sh",
    "audit:theme-architecture": "tsx scripts/audit-theme-architecture.ts",
    "audit:theme-architecture:strict": "tsx scripts/audit-theme-architecture.ts --strict",
    "audit:theme-architecture:baseline": "tsx scripts/audit-theme-architecture.ts --write-baseline",
    "audit:theme-ui": "tsx scripts/audit-theme-architecture.ts --ui-only",
    "audit:theme-ui:baseline": "tsx scripts/audit-theme-architecture.ts --ui-only --write-baseline",
    "audit:theme-ui:strict": "tsx scripts/audit-theme-architecture.ts --ui-only --strict",
    "check:theme-contracts": "tsx scripts/validate-theme-contracts.ts",
    "check:theme-visual-regression": "node scripts/theme-visual-regression.mjs",
    "theme:remediate:contrast": "tsx server/scripts/remediateThemeContrast.ts",
    "theme:remediate:contrast:live": "tsx server/scripts/remediateThemeContrast.ts --live",
    "theme:prune-invalid": "tsx server/scripts/pruneInvalidThemes.ts",
    "theme:prune-invalid:live": "tsx server/scripts/pruneInvalidThemes.ts --live",
    "storage:compact-long-paths": "tsx server/scripts/compactLongUploadPaths.ts",
    "storage:compact-long-paths:live": "tsx server/scripts/compactLongUploadPaths.ts --live",
    "theme:migrate-preset-ids": "tsx server/scripts/migrateThemePresetIdsToCatalog.ts",
    "theme:migrate-preset-ids:live": "tsx server/scripts/migrateThemePresetIdsToCatalog.ts --live",
    "podcast:hls:backfill": "tsx server/scripts/backfillPodcastHls.ts",
    "podcast:hls:backfill:live": "tsx server/scripts/backfillPodcastHls.ts --live",
    "translation:reconcile": "tsx server/scripts/reconcileTranslationRecords.ts",
    "translation:reconcile:live": "tsx server/scripts/reconcileTranslationRecords.ts --live",
    "migration:validate": "node scripts/migration-governance.mjs validate",
    "migration:drift:check": "node scripts/migration-governance.mjs detect-drift --db-url \"$DATABASE_URL\"",
    "migration:verify:dev:cloud": "node scripts/migration-governance.mjs verify-dev --deployment-mode cloud --db-url \"$DATABASE_URL\" --auto-remediate",
    "migration:verify:dev:onprem": "node scripts/migration-governance.mjs verify-dev --deployment-mode onprem --db-url \"$DATABASE_URL\" --auto-remediate",
    "migration:verify:runtime:cloud": "node scripts/migration-governance.mjs verify-runtime-contract --deployment-mode cloud --db-url \"$DATABASE_URL\"",
    "migration:verify:runtime:onprem": "node scripts/migration-governance.mjs verify-runtime-contract --deployment-mode onprem --db-url \"$DATABASE_URL\"",
    "check:elevenlabs-endpoints": "scripts/validate-elevenlabs-endpoints.sh",
    "db:push": "drizzle-kit push",
    "schema:contract:gen:cloud": "scripts/schema/generate-contract.sh --product cloud",
    "schema:contract:gen:onprem": "scripts/schema/generate-contract.sh --product onprem",
    "schema:contract:gen:shared": "scripts/schema/generate-shared-contract.sh",
    "schema:contract:validate:cloud": "scripts/schema/validate-contract.sh --product cloud",
    "schema:contract:validate:onprem": "scripts/schema/validate-contract.sh --product onprem",
    "schema:contract:validate:shared": "scripts/schema/validate-shared.sh",
    "load:seed:cloud": "bash scripts/load/seed-load-users.sh --variant cloud --count 2600",
    "load:seed:onprem": "bash scripts/load/seed-load-users.sh --variant onprem --count 2600",
    "load:test:app2000:cloud": "bash tests/load/run-k6.sh run --env BASE_URL=https://stcloud.learnplay.co.za --env VARIANT=cloud --env USER_CSV=data/users-cloud.csv tests/load/k6-app-2000.js",
    "load:test:app2000:onprem": "bash tests/load/run-k6.sh run --env BASE_URL=https://stonprem.learnplay.co.za --env VARIANT=onprem --env USER_CSV=data/users-onprem.csv tests/load/k6-app-2000.js",
    "load:test:appshort:cloud": "bash tests/load/run-k6.sh run --env LOAD_PROFILE=short --env BASE_URL=https://stcloud.learnplay.co.za --env VARIANT=cloud --env USER_CSV=data/users-cloud.csv tests/load/k6-app-2000.js",
    "load:test:appshort:onprem": "bash tests/load/run-k6.sh run --env LOAD_PROFILE=short --env BASE_URL=https://stonprem.learnplay.co.za --env VARIANT=onprem --env USER_CSV=data/users-onprem.csv tests/load/k6-app-2000.js",
    "load:test:appshort:cloud:devsafe": "bash tests/load/run-k6.sh run --env LOAD_PROFILE=short --env K6_INSECURE_TLS=true --env BASE_URL=https://stcloud.learnplay.co.za --env VARIANT=cloud --env USER_CSV=data/users-cloud.csv tests/load/k6-app-2000.js",
    "load:test:appshort:onprem:devsafe": "bash tests/load/run-k6.sh run --env LOAD_PROFILE=short --env K6_INSECURE_TLS=true --env ONPREM_SYSTEM_TYPE=development --env BASE_URL=https://stonprem.learnplay.co.za --env VARIANT=onprem --env USER_CSV=data/users-onprem.csv tests/load/k6-app-2000.js"
  },
