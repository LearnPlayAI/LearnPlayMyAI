// Launch In Minutes Section - Replaces HowQuizWorksSection
const LaunchInMinutesSection = () => {
  const steps = [
    {
      number: 1,
      title: 'Upload',
      subtitle: 'Your Content',
      description: 'Upload your Word documents, PowerPoints, or simply describe what you want to teach.',
      icon: <Upload className="w-10 h-10" />,
      gradient: 'from-secondary to-secondary',
