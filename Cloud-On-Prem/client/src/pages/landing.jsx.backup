      icon: <Sparkles className="w-10 h-10" />,
      gradient: 'from-hero-headline-from to-hero-headline-to',
      time: '5 min'
    },
    {
      number: 3,
      title: 'Review & Publish',
      subtitle: 'In Minutes',
      description: 'Polish with your expertise and publish to your learners in minutes, not days.',
      icon: <Play className="w-10 h-10" />,
      gradient: 'from-primary to-primary',
      time: '3 min'
    }
  ];

  return (
    <div className="w-full max-w-7xl mx-auto px-4 py-20" data-testid="section-launch-in-minutes">
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        className="text-center mb-16"
      >
        <h2 className="text-[length:var(--text-3xl)] sm:text-[length:var(--text-4xl)] md:text-[length:var(--text-5xl)] font-black mb-4">
          <span className="bg-gradient-to-r from-secondary via-primary to-accent bg-clip-text text-transparent">
            Launch in Minutes, Not Days
          </span>
        </h2>
        <p className="text-base sm:text-lg md:text-xl max-w-2xl mx-auto" style={{ color: 'var(--section-subheading)' }}>
          From idea to published course in under 10 minutes - our AI handles the heavy lifting
        </p>
      </motion.div>

      <div className="relative">
        <div className="hidden lg:block absolute top-1/2 left-0 right-0 h-1 bg-gradient-to-r from-secondary via-primary to-accent opacity-30 -translate-y-1/2 mx-20" data-testid="progress-line"></div>
        
        <div className="grid grid-cols-1 lg:grid-cols-3 gap-8 relative">
          {steps.map((step, index) => (
            <motion.div
              key={index}
              initial={{ opacity: 0, y: 30 }}
              whileInView={{ opacity: 1, y: 0 }}
              viewport={{ once: true }}
              transition={{ duration: 0.6, delay: index * 0.2 }}
              className="relative"
              data-testid={`workflow-step-${index + 1}`}
            >
              <div className="relative">
                {index < steps.length - 1 && (
                  <div className="hidden lg:flex absolute top-1/2 -right-4 transform -translate-y-1/2 z-10">
                    <motion.div
                      initial={{ opacity: 0, x: -10 }}
                      whileInView={{ opacity: 1, x: 0 }}
                      viewport={{ once: true }}
                      transition={{ duration: 0.4, delay: index * 0.2 + 0.3 }}
                    >
                      <ChevronRight className="w-8 h-8 text-primary" />
                    </motion.div>
                  </div>
                )}

                <div className="group relative p-8 bg-gradient-to-br from-card/80 to-card/50 backdrop-blur-xl rounded-3xl border border-border hover:border-primary/40 transition-all duration-300 hover:scale-105 hover:shadow-dialog">
                  <div className={`absolute -top-5 left-1/2 -translate-x-1/2 w-10 h-10 bg-gradient-to-br ${step.gradient} rounded-full flex items-center justify-center text-primary-foreground font-black text-lg shadow-elevated z-10`}>
                    {step.number}
                  </div>

                  <div className="absolute top-4 right-4 px-3 py-1 bg-gradient-to-r from-[hsl(var(--warning)/0.2)] to-[hsl(var(--accent)/0.2)] border border-[hsl(var(--warning)/0.3)] rounded-full">
                    <div className="flex items-center gap-1.5">
                      <Clock className="w-3.5 h-3.5 text-accent" />
                      <span className="text-accent font-bold text-sm">{step.time}</span>
                    </div>
                  </div>

                  <div className={`w-20 h-20 mx-auto mb-6 mt-4 bg-gradient-to-br ${step.gradient} rounded-2xl flex items-center justify-center text-primary-foreground shadow-elevated group-hover:shadow-dialog transition-shadow`}>
                    {step.icon}
                  </div>

                  <div className="text-center">
                    <h3 className="text-2xl font-bold text-foreground">{step.title}</h3>
                    <p className={`text-lg font-semibold bg-gradient-to-r ${step.gradient} bg-clip-text text-transparent mb-3`}>
                      {step.subtitle}
                    </p>
                    <p className="text-muted-foreground leading-relaxed">{step.description}</p>
                  </div>

                  <div className={`absolute inset-0 bg-gradient-to-br ${step.gradient} opacity-0 group-hover:opacity-10 rounded-3xl transition-opacity blur-2xl`}></div>
                </div>
              </div>
            </motion.div>
          ))}
        </div>
      </div>

      <motion.div
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6, delay: 0.6 }}
        className="text-center mt-16"
        data-testid="time-savings-indicator"
      >
        <div className="inline-flex flex-col sm:flex-row items-center gap-4 p-6 bg-gradient-to-r from-primary/20 to-primary/20 border border-primary/30 rounded-2xl">
          <div className="flex items-center gap-3">
            <div className="w-12 h-12 bg-gradient-to-br from-[hsl(var(--destructive)/0.3)] to-[hsl(var(--destructive)/0.3)] rounded-full flex items-center justify-center border border-[hsl(var(--destructive)/0.3)]">
              <span className="text-destructive font-bold line-through">Days</span>
            </div>
            <ArrowRight className="w-6 h-6 text-muted-foreground" />
            <div className="w-12 h-12 bg-gradient-to-br from-primary to-primary rounded-full flex items-center justify-center shadow-elevated">
              <span className="text-primary-foreground font-bold">10m</span>
            </div>
          </div>
          <div className="text-left">
            <p className="text-primary/90 font-bold text-lg">Total Time: ~10 Minutes</p>
            <p className="text-muted-foreground text-sm">From content upload to published course</p>
          </div>
        </div>
      </motion.div>
    </div>
  );
};


