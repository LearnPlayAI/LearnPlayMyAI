      gradient: 'from-primary to-primary',
      glowColor: 'green'
    },
    {
      id: 'download-edit',
      title: 'Download & Edit',
      description: 'Export courses and lessons as editable files. Customize content for your specific needs and preferences.',
      icon: <Download className="w-8 h-8" />,
      gradient: 'from-[hsl(var(--secondary))] to-[hsl(var(--secondary)/0.8)]',
      glowColor: 'pink'
    },
    {
      id: 'video-generation',
      title: 'Video Generation',
      description: 'Convert PowerPoint and lessons into engaging video content automatically with professional narration.',
      icon: <Play className="w-8 h-8" />,
      gradient: 'from-secondary to-primary',
      glowColor: 'secondary'
    }
  ];

  return (
    <div className="w-full max-w-7xl mx-auto px-4 py-20" data-testid="section-platform-capabilities">
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        className="text-center mb-16"
      >
        <h2 className="text-[length:var(--text-3xl)] sm:text-[length:var(--text-4xl)] md:text-[length:var(--text-5xl)] font-black mb-4" data-testid="title-platform-capabilities">
          <span className="bg-gradient-to-r from-secondary via-primary to-accent bg-clip-text text-transparent">
            Everything You Need to Succeed
          </span>
        </h2>
        <p className="text-base sm:text-lg md:text-xl max-w-2xl mx-auto" style={{ color: 'var(--section-subheading)' }} data-testid="subtitle-platform-capabilities">
          Powerful tools that make learning management effortless
        </p>
      </motion.div>

      <div className="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        {capabilities.map((capability, index) => (
          <motion.div
            key={capability.id}
            initial={{ opacity: 0, y: 30 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5, delay: index * 0.1 }}
            data-testid={`card-capability-${capability.id}`}
          >
            <div 
              className="group h-full relative p-6 backdrop-blur-xl rounded-2xl transition-all duration-300 hover:scale-[1.03] hover:shadow-dialog"
              style={{
                backgroundColor: 'var(--glass-card-bg)',
                borderWidth: '1px',
                borderStyle: 'solid',
                borderColor: 'var(--glass-card-border)',
              }}
              onMouseEnter={(e) => e.currentTarget.style.borderColor = 'var(--glass-card-hover-border)'}
              onMouseLeave={(e) => e.currentTarget.style.borderColor = 'var(--glass-card-border)'}
            >
              <div className={`w-16 h-16 mb-5 bg-gradient-to-br ${capability.gradient} rounded-2xl flex items-center justify-center text-primary-foreground shadow-elevated group-hover:shadow-elevated transition-all duration-300 group-hover:scale-110`}>
                {capability.icon}
              </div>

              <h3 className="text-xl font-bold mb-3" style={{ color: 'var(--glass-card-title)' }} data-testid={`title-capability-${capability.id}`}>
                {capability.title}
              </h3>

              <p className="text-sm leading-relaxed" style={{ color: 'var(--glass-card-body)' }} data-testid={`desc-capability-${capability.id}`}>
                {capability.description}
              </p>

              <div className={`absolute inset-0 bg-gradient-to-br ${capability.gradient} opacity-0 group-hover:opacity-10 rounded-2xl transition-opacity duration-300 blur-2xl -z-10`}></div>
            </div>
          </motion.div>
        ))}
      </div>
    </div>
  );
};

