// Bonus Card Game Section (Arcade Style)
const BonusCardGameSection = () => {
  const [selectedCollection, setSelectedCollection] = useState(null);
  const [isModalOpen, setIsModalOpen] = useState(false);
  const { orgName } = useBrandingLogo();

  const { data: collections, isLoading } = useQuery({
    queryKey: ["/api/collections"],
    retry: false,
  });

  const handleCollectionClick = (collection) => {
    setSelectedCollection(collection);
    setIsModalOpen(true);
  };

  const handleModalClose = () => {
    setIsModalOpen(false);
    setSelectedCollection(null);
  };

  return (
    <div className="w-full max-w-7xl mx-auto px-4 py-20">
      {/* Section Header with Arcade Styling */}
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        className="text-center mb-12"
      >
        {/* Bonus Badge */}
        <div className="inline-flex items-center gap-2 px-6 py-3 bg-gradient-to-r from-[hsl(var(--warning)/0.2)] to-[hsl(var(--accent)/0.2)] backdrop-blur-sm border-2 border-[hsl(var(--accent)/0.5)] rounded-full text-accent text-sm font-bold mb-6 shadow-elevated shadow-[hsl(var(--warning)/0.2)]">
          <Sparkles className="w-5 h-5 animate-pulse" />
          <span>BONUS FEATURE</span>
          <Sparkles className="w-5 h-5 animate-pulse" />
        </div>

        <h2 className="text-4xl md:text-5xl font-black mb-4">
          <span className="bg-gradient-to-r from-[hsl(var(--accent))] via-[hsl(var(--warning))] to-[hsl(var(--warning))] bg-clip-text text-transparent drop-shadow-elevated">
            {orgName} Card Battle
          </span>
        </h2>
        <p className="text-xl text-muted-foreground max-w-2xl mx-auto">
          Take a brain break with our bonus card battle game - compare stats and dominate opponents!
        </p>
      </motion.div>

      {/* Arcade-Style Container */}
      <motion.div
        initial={{ opacity: 0, y: 30 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6, delay: 0.2 }}
        className="relative p-8 md:p-12 bg-gradient-to-br from-primary/30 to-black/60 backdrop-blur-sm rounded-3xl border-4 border-[hsl(var(--accent)/0.3)] shadow-dialog shadow-[var(--game-glow)]"
      >
        {/* Neon Corner Accents */}
        <div className="absolute top-0 left-0 w-16 h-16 border-l-4 border-t-4 border-[hsl(var(--accent))] rounded-tl-2xl"></div>
        <div className="absolute top-0 right-0 w-16 h-16 border-r-4 border-t-4 border-[hsl(var(--accent))] rounded-tr-2xl"></div>
        <div className="absolute bottom-0 left-0 w-16 h-16 border-l-4 border-b-4 border-[hsl(var(--accent))] rounded-bl-2xl"></div>
        <div className="absolute bottom-0 right-0 w-16 h-16 border-r-4 border-b-4 border-[hsl(var(--accent))] rounded-br-2xl"></div>

        {/* Collections Grid */}
        {isLoading ? (
          <div className="text-center py-12">
            <div className="inline-block w-12 h-12 border-4 border-[hsl(var(--accent))] border-t-transparent rounded-full animate-spin"></div>
          </div>
        ) : (
          <>
            <div className="grid grid-cols-2 md:grid-cols-3 lg:grid-cols-6 gap-4 mb-8">
              {collections?.slice(0, 6).map((collection, index) => (
                <motion.div
                  key={collection.id}
                  initial={{ opacity: 0, scale: 0.8 }}
                  whileInView={{ opacity: 1, scale: 1 }}
                  viewport={{ once: true }}
                  transition={{ duration: 0.4, delay: index * 0.1 }}
                  className="group cursor-pointer"
                  onClick={() => handleCollectionClick(collection)}
                >
                  <div className="relative aspect-[3/4] rounded-xl overflow-hidden border-2 border-[hsl(var(--accent)/0.3)] hover:border-[hsl(var(--accent))] transition-all duration-300 hover:scale-105 hover:shadow-dialog hover:shadow-[hsl(var(--accent)/0.3)]">
                    <div 
                      className="absolute inset-0 bg-cover bg-center"
                      style={{ 
                        backgroundImage: collection?.imageKey 
                          ? `url(/api/collections/${collection.id}/cover-image)` 
                          : `url(${trexCardImage})`
                      }}
                    />
                    <div className="absolute inset-0 bg-gradient-to-t from-black/80 via-black/20 to-transparent"></div>
                    <div className="absolute bottom-0 left-0 right-0 p-3">
                      <p className="text-accent font-bold text-sm truncate">{collection.name}</p>
                      <p className="text-xs text-muted-foreground">{collection.totalCards} Cards</p>
                    </div>
                    
                    {/* Play overlay */}
                    <div className="absolute inset-0 bg-black/60 backdrop-blur-sm flex items-center justify-center opacity-0 group-hover:opacity-100 transition-opacity">
                      <div className="bg-[hsl(var(--accent))] text-accent-foreground px-4 py-2 rounded-lg font-bold">
                        PLAY NOW
                      </div>
                    </div>
                  </div>
                </motion.div>
              ))}
            </div>

            {/* Play Card Battle CTA */}
            <div className="text-center">
              <Link href="/game-lobby">
                <button className="group px-8 py-4 bg-gradient-to-r from-[hsl(var(--accent))] to-[hsl(var(--warning))] hover:from-[hsl(var(--accent)/0.9)] hover:to-[hsl(var(--warning)/0.9)] text-accent-foreground font-black rounded-xl transition-all duration-300 hover:scale-105 shadow-elevated shadow-[hsl(var(--warning)/0.5)] hover:shadow-dialog hover:shadow-[hsl(var(--accent)/0.6)] text-lg" data-testid="button-card-battle">
                  <div className="flex items-center gap-3">
                    <Trophy className="w-6 h-6" />
                    <span>Enter Card Battle Arena</span>
                    <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                  </div>
                </button>
              </Link>
            </div>
          </>
        )}
      </motion.div>

      {/* Collection Modal */}
      {selectedCollection && (
        <CollectionModal
          collection={selectedCollection}
          isOpen={isModalOpen}
          onClose={handleModalClose}
        />
      )}
    </div>
  );
};

// Cache Clear Button Component
const CacheClearButton = () => {
  const [isClearing, setIsClearing] = useState(false);
  const [showConfirm, setShowConfirm] = useState(false);

  const handleClearCache = () => {
    setIsClearing(true);
    
    try {
      localStorage.clear();
      sessionStorage.clear();
      
      if ('caches' in window) {
        caches.keys().then(names => {
          names.forEach(name => {
            caches.delete(name);
          });
        });
      }
      
      setTimeout(() => {
        setIsClearing(false);
        setShowConfirm(false);
        window.location.reload(true);
      }, 500);
    } catch (error) {
      console.error('Error clearing cache:', error);
      setIsClearing(false);
      setShowConfirm(false);
    }
  };

  return (
    <div className="fixed bottom-6 right-6 z-50" data-testid="cache-clear-container">
      {showConfirm ? (
        <motion.div 
          className="bg-card border border-border rounded-lg shadow-dialog p-4 max-w-xs"
          initial={{ scale: 0.8, opacity: 0 }}
          animate={{ scale: 1, opacity: 1 }}
        >
          <p className="text-sm text-foreground mb-3">Clear all site cache and reload? This will sign you out.</p>
          <div className="flex gap-2">
            <button
              onClick={handleClearCache}
              disabled={isClearing}
              className="flex-1 px-3 py-2 bg-destructive hover:bg-destructive/90 text-destructive-foreground text-sm font-medium rounded-lg transition-all disabled:opacity-50"
              data-testid="button-confirm-clear"
            >
              {isClearing ? 'Clearing...' : 'Clear Cache'}
            </button>
            <button
              onClick={() => setShowConfirm(false)}
              className="flex-1 px-3 py-2 bg-muted hover:bg-muted/80 text-foreground text-sm font-medium rounded-lg transition-all"
              data-testid="button-cancel-clear"
            >
              Cancel
            </button>
          </div>
        </motion.div>
      ) : (
        <button
          onClick={() => setShowConfirm(true)}
          className="px-3 py-2 bg-muted hover:bg-muted/80 text-muted-foreground hover:text-foreground text-xs font-medium rounded-lg transition-all border border-border shadow-elevated"
          data-testid="button-open-clear-cache"
          title="Clear site cache"
        >
          🗑️ Clear Cache
        </button>
      )}
    </div>
  );
};

