              className="relative h-auto md:h-[550px] lg:h-[650px]"
              initial={{ opacity: 0, x: 50 }}
              animate={{ opacity: 1, x: 0 }}
              transition={{ duration: 0.8, delay: 0.4 }}
              data-testid="creation-demo"
            >
              {/* Creation Flow Demo */}
              <div className="relative w-full h-full flex flex-col items-center justify-center">
                {/* Main creation card with AnimatePresence for smooth transitions */}
                <AnimatePresence mode="wait">
                  <motion.div
                    key={activeCreationStep}
                    initial={{ opacity: 0, x: 20 }}
                    animate={{ opacity: 1, x: 0 }}
                    exit={{ opacity: 0, x: -20 }}
                    transition={{ duration: 0.25, ease: "easeOut" }}
                    drag="x"
                    dragConstraints={{ left: 0, right: 0 }}
                    dragElastic={0.2}
                    onDragEnd={(e, { offset, velocity }) => {
                      const swipe = Math.abs(offset.x) * velocity.x;
                      if (swipe < -50) {
                        setActiveCreationStep((prev) => Math.min(prev + 1, creationSteps.length - 1));
                      } else if (swipe > 50) {
                        setActiveCreationStep((prev) => Math.max(prev - 1, 0));
                      }
                    }}
                    className="w-full max-w-md bg-gradient-to-br from-card/80 to-card/50 backdrop-blur-xl rounded-3xl border border-border shadow-dialog overflow-hidden cursor-grab active:cursor-grabbing touch-pan-y"
                    data-testid="creation-card"
                  >
                    <div className="p-4 sm:p-6 md:p-8">
                      {/* Header */}
                      <div className="flex items-center justify-between mb-4">
                        <div>
                          <h3 className="text-foreground font-bold text-lg">{creationSteps[activeCreationStep].title}</h3>
                          <p className="text-primary/80 text-xs">{creationSteps[activeCreationStep].subtitle}</p>
                        </div>
                        <div className="flex items-center gap-1 px-2 py-1 bg-primary/20 rounded-full">
                          <Brain className="w-4 h-4 text-primary" />
                          <span className="text-primary/80 text-xs font-semibold">AI</span>
                        </div>
                      </div>
                      
                      {/* Dynamic Content */}
                      {creationSteps[activeCreationStep].content}
                    </div>
                  </motion.div>
                </AnimatePresence>

                {/* Swipe indicator dots - visible on mobile */}
                <div className="flex items-center justify-center gap-2 mt-4 md:hidden" data-testid="swipe-indicators">
                  {creationSteps.map((_, index) => (
                    <button
                      key={index}
                      onClick={() => setActiveCreationStep(index)}
                      className={`min-w-[44px] min-h-[44px] flex items-center justify-center touch-manipulation`}
                      aria-label={`Go to step ${index + 1}`}
                    >
                      <span
                        className={`w-2.5 h-2.5 rounded-full transition-all duration-300 ${
                          activeCreationStep === index
                            ? 'bg-primary scale-125'
                            : 'bg-muted/50 hover:bg-muted'
                        }`}
                      />
                    </button>
                  ))}
                  <span className="text-xs text-muted-foreground ml-2">Swipe to navigate</span>
                </div>

              </div>
            </motion.div>
          </div>
        </div>
      </div>
      {/* Bottom fade */}
      <div className="absolute bottom-0 left-0 right-0 h-32 bg-gradient-to-t from-background to-transparent pointer-events-none"></div>
    </div>
  );
};

// Popular Courses Section - Fetches and displays top-rated courses
const PopularCoursesSection = () => {
  const { data, isLoading, error } = useQuery({
    queryKey: ['/api/public/popular-courses'],
    retry: 1,
  });
  
  const courses = data?.courses || [];
  
  const { 
    displayCurrency, 
    formatPrice, 
    setGuestCurrencyPreference, 
    availableCurrencies 
  } = useCurrencyDisplay();

  const renderStars = (rating) => {
    const fullStars = Math.floor(rating || 0);
    const hasHalfStar = (rating || 0) % 1 >= 0.5;
    const emptyStars = 5 - fullStars - (hasHalfStar ? 1 : 0);
    
    return (
      <div className="flex items-center gap-0.5" data-testid="course-rating-stars">
        {[...Array(fullStars)].map((_, i) => (
          <Star key={`full-${i}`} className="w-4 h-4 fill-accent text-accent" />
        ))}
        {hasHalfStar && (
          <div className="relative">
            <Star className="w-4 h-4 text-muted-foreground" />
            <div className="absolute inset-0 overflow-hidden w-1/2">
              <Star className="w-4 h-4 fill-accent text-accent" />
            </div>
          </div>
        )}
        {[...Array(emptyStars)].map((_, i) => (
          <Star key={`empty-${i}`} className="w-4 h-4 text-muted-foreground" />
        ))}
      </div>
    );
  };

  const getDifficultyBadge = (difficulty) => {
    const colors = {
      beginner: 'bg-[hsl(var(--success)/0.2)] text-success border-[hsl(var(--success)/0.3)]',
      intermediate: 'bg-[hsl(var(--warning)/0.2)] text-warning border-[hsl(var(--warning)/0.3)]',
      advanced: 'bg-[hsl(var(--destructive)/0.2)] text-destructive border-[hsl(var(--destructive)/0.3)]',
    };
    return colors[difficulty?.toLowerCase()] || colors.beginner;
  };

  const SkeletonCard = () => (
    <div className="bg-gradient-to-br from-muted/20 to-muted/10 backdrop-blur-sm rounded-2xl border border-border overflow-hidden animate-pulse">
      <div className="h-40 bg-muted/20"></div>
      <div className="p-4 space-y-3">
        <div className="h-5 bg-muted/20 rounded w-3/4"></div>
        <div className="h-4 bg-muted/20 rounded w-1/2"></div>
        <div className="flex justify-between items-center">
          <div className="h-4 bg-muted/20 rounded w-20"></div>
          <div className="h-6 bg-muted/20 rounded w-16"></div>
        </div>
      </div>
    </div>
  );

  return (
    <div className="w-full max-w-7xl mx-auto px-4 py-20" data-testid="section-popular-courses">
      <motion.div
        initial={{ opacity: 0, y: 20 }}
        whileInView={{ opacity: 1, y: 0 }}
        viewport={{ once: true }}
        transition={{ duration: 0.6 }}
        className="text-center mb-12"
      >
        <h2 className="text-[length:var(--text-3xl)] sm:text-[length:var(--text-4xl)] md:text-[length:var(--text-5xl)] font-black mb-4">
          <span className="bg-gradient-to-r from-primary via-secondary to-[hsl(var(--accent))] bg-clip-text text-transparent">
            Popular Courses
          </span>
        </h2>
        <p className="text-base sm:text-lg md:text-xl text-muted-foreground max-w-2xl mx-auto">
          Discover top-rated courses created by our community of educators
        </p>
        <div className="flex justify-center mt-4">
          <CurrencySelectorBadge
            onCurrencyChange={setGuestCurrencyPreference}
            currentCurrency={displayCurrency}
            availableCurrencies={availableCurrencies}
            className="bg-muted/20 p-2 rounded-lg border border-border"
          />
        </div>
      </motion.div>

      {isLoading ? (
        <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" data-testid="courses-skeleton-grid">
          {[...Array(4)].map((_, i) => (
            <SkeletonCard key={i} />
          ))}
        </div>
      ) : error || courses.length === 0 ? (
        <motion.div
          initial={{ opacity: 0, y: 20 }}
          whileInView={{ opacity: 1, y: 0 }}
          viewport={{ once: true }}
          className="text-center py-16"
          data-testid="courses-empty-state"
        >
          <div className="w-24 h-24 mx-auto mb-6 bg-gradient-to-br from-primary/20 to-secondary/20 rounded-full flex items-center justify-center">
            <GraduationCap className="w-12 h-12 text-primary" />
          </div>
          <h3 className="text-2xl font-bold text-foreground mb-3">Courses Coming Soon</h3>
          <p className="text-muted-foreground max-w-md mx-auto mb-6">
            Our educators are creating amazing courses. Check back soon to explore our growing library!
          </p>
          <Link href="/browse-courses">
            <button 
              className="min-h-[44px] px-6 py-3 bg-gradient-to-r from-primary to-secondary hover:from-primary/90 hover:to-secondary/90 text-primary-foreground font-bold rounded-xl transition-all hover:scale-105 touch-manipulation"
              data-testid="button-browse-all-courses-empty"
            >
              Browse All Courses
            </button>
          </Link>
        </motion.div>
      ) : (
        <>
          <div className="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-6" data-testid="courses-grid">
            {courses.slice(0, 8).map((course, index) => (
              <motion.div
                key={course.id}
                initial={{ opacity: 0, y: 30 }}
                whileInView={{ opacity: 1, y: 0 }}
                viewport={{ once: true }}
                transition={{ duration: 0.5, delay: index * 0.1 }}
                className="group"
              >
                <Link href={`/course/${course.id}`}>
                  <div 
                    className="bg-gradient-to-br from-card/80 to-card/50 backdrop-blur-sm rounded-2xl border border-border hover:border-primary/50 transition-all duration-300 hover:scale-105 hover:shadow-dialog hover:shadow-[var(--game-glow)] overflow-hidden cursor-pointer"
                    data-testid={`course-card-${course.id}`}
                  >
                    <div className="relative h-40 bg-gradient-to-br from-primary/30 to-secondary/30">
                      {course.thumbnailUrl ? (
                        <img 
                          src={course.thumbnailUrl} 
                          alt={course.title}
                          className="w-full h-full object-cover"
                          data-testid={`course-thumbnail-${course.id}`}
                        />
                      ) : (
                        <div className="w-full h-full flex items-center justify-center">
                          <GraduationCap className="w-16 h-16 text-primary/50" />
                        </div>
                      )}
                      <div className="absolute top-3 right-3">
                        <span 
                          className={`px-2 py-1 text-xs font-semibold rounded-full border ${getDifficultyBadge(course.difficulty)}`}
                          data-testid={`course-difficulty-${course.id}`}
                        >
                          {course.difficulty || 'Beginner'}
                        </span>
                      </div>
                    </div>
                    
                    <div className="p-4 space-y-3">
                      <h3 
                        className="text-lg font-bold text-foreground line-clamp-2 group-hover:text-primary transition-colors"
                        data-testid={`course-title-${course.id}`}
                      >
                        {course.title}
                      </h3>
                      
                      <div className="flex items-center gap-2">
                        {renderStars(course.averageRating)}
                        <span className="text-sm text-muted-foreground" data-testid={`course-rating-value-${course.id}`}>
                          ({course.totalRatings || 0})
                        </span>
                      </div>
                      
                      <div className="flex justify-between items-center pt-2">
                        <div className="flex items-center gap-1 text-muted-foreground">
                          <BookOpen className="w-4 h-4" />
                          <span className="text-sm">{course.lessonCount || 0} lessons</span>
                        </div>
                        <div 
                          className="text-lg font-bold text-accent"
                          data-testid={`course-price-${course.id}`}
                        >
                          {course.price ? formatPrice(course.price, 'ZAR') : 'Free'}
                        </div>
                      </div>
                    </div>
                  </div>
                </Link>
              </motion.div>
            ))}
          </div>

          <motion.div
            initial={{ opacity: 0, y: 20 }}
            whileInView={{ opacity: 1, y: 0 }}
            viewport={{ once: true }}
            transition={{ duration: 0.5, delay: 0.3 }}
            className="text-center mt-12"
          >
            <Link href="/browse-courses">
              <button 
                className="group px-8 py-4 bg-gradient-to-r from-primary to-secondary hover:from-primary/90 hover:to-secondary/90 text-primary-foreground font-bold rounded-xl transition-all hover:scale-105 shadow-elevated hover:shadow-[var(--game-glow)]"
                data-testid="button-view-all-courses"
              >
                <div className="flex items-center gap-3">
                  <span>View All Courses</span>
                  <ArrowRight className="w-5 h-5 group-hover:translate-x-1 transition-transform" />
                </div>
              </button>
            </Link>
          </motion.div>
        </>
      )}
    </div>
  );
};

